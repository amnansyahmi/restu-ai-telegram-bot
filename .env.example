TELEGRAM_BOT_TOKEN=123456789:replace_with_your_botfather_token
PUBLIC_URL=https://your-render-service.onrender.com
PORT=3000

# Optional: connect Ask Restu AI later
RESTU_AI_URL=
RESTU_AI_API_KEY=
AI_NONYMAUZ_CLOUD_URL=
AI_NONYMAUZ_CLOUD_API_KEY=
# Model id served by ai-nonymauz-cloud (defaults to restu-ai)
AI_NONYMAUZ_CLOUD_MODEL=

# Supabase project settings (recommended for persistent data)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Protect scheduled reminder calls
CRON_SECRET=replace_with_a_long_random_value
WEBHOOK_SECRET=replace_with_letters_numbers_underscore_or_hyphen

# Local UI testing only; never enable on Render
DISABLE_BOT_START=false
